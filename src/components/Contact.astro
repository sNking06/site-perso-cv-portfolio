---
import Icon from "./Icon.astro";
import type { Contact, Profile, SocialLink } from "../data/cv";

interface Props {
  contact: Contact;
  socialLinks: SocialLink[];
  profile: Profile;
}

const { contact, socialLinks, profile } = Astro.props;
const mailHref = contact.email.includes("@") ? `mailto:${contact.email}` : "#";
---

<div class="contact-grid reveal">
  <div class="contact-main">
    <p>
      Un de mes projets vous intrigue ? Vous bidouillez aussi avec les LLM, l'automatisation ou le support IT ?
      Écrivez-moi par email ou LinkedIn — les meilleures conversations commencent souvent comme ça.
    </p>
    <div class="contact-actions">
      <a class="button button-primary" href={mailHref}>
        <Icon name="mail" size={18} />
        <span>{contact.email}</span>
      </a>
      {socialLinks.map((link) => (
        <a class="button button-secondary" href={link.url} target={link.url.startsWith("#") ? undefined : "_blank"} rel={link.url.startsWith("#") ? undefined : "noopener noreferrer"}>
          <Icon name={link.platform.toLowerCase() === "github" ? "github" : "linkedin"} size={18} />
          <span>{link.platform}</span>
        </a>
      ))}
    </div>
  </div>

  <aside class="contact-side surface-card" aria-label="Informations de contact">
    <dl>
      <div>
        <dt>Localisation</dt>
        <dd>{profile.location}</dd>
      </div>
      <div>
        <dt>Disponibilité</dt>
        <dd>{profile.availability}</dd>
      </div>
    </dl>
  </aside>
</div>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 340px);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .contact-main p {
    max-width: 720px;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1.02rem, 2vw, 1.16rem);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .contact-side {
    padding: 1.25rem;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

  dt {
    color: var(--color-subtle);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  dd {
    margin: 0.15rem 0 0;
    color: var(--color-text);
    font-weight: 750;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .contact-actions :global(.button) {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
