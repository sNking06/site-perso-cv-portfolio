---
import Icon from "./Icon.astro";
import type { SkillCategory } from "../data/cv";

interface Props {
  skills: SkillCategory[];
}

const { skills } = Astro.props;
---

<div class="skills-grid">
  {skills.map((group) => (
    <article class="skill-card surface-card reveal">
      <div class="skill-heading">
        <span class="skill-icon" aria-hidden="true"><Icon name={group.icon} /></span>
        <h3>{group.category}</h3>
      </div>
      <ul>
        {group.items.map((item) => (
          <li>
            <span>{item.name}</span>
            {item.level && <small>{item.level}</small>}
          </li>
        ))}
      </ul>
    </article>
  ))}
</div>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .skill-card {
    padding: 1.25rem;
    transition: box-shadow 180ms ease, transform 180ms ease;
  }

  .skill-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }

  .skill-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .skill-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: var(--radius-md);
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.25;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #f9fafb;
    padding: 0.35rem 0.65rem;
    color: var(--color-text);
    font-size: 0.92rem;
    font-weight: 700;
  }

  small {
    color: var(--color-subtle);
    font-size: 0.78rem;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .skills-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
