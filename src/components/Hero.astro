---
import CVDownloadButton from "./CVDownloadButton.astro";
import Icon from "./Icon.astro";
import { PLACEHOLDER } from "../data/cv";
import type { Meta, Profile } from "../data/cv";

interface Props {
  profile: Profile;
  meta: Meta;
}

const { profile, meta } = Astro.props;
const fullName = profile.firstName === PLACEHOLDER && profile.lastName === PLACEHOLDER
  ? PLACEHOLDER
  : `${profile.firstName} ${profile.lastName}`.trim();
const initials = profile.firstName === PLACEHOLDER ? "IT" : `${profile.firstName.slice(0, 1)}${profile.lastName.slice(0, 1)}`;
---

<section id="accueil" class="hero" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy reveal">
      <p class="availability">{profile.availability}</p>
      <h1 id="hero-title">{fullName}</h1>
      <p class="hero-title">{profile.title}</p>
      <p class="hero-tagline">{profile.tagline}</p>
      <div class="hero-actions" aria-label="Actions principales">
        <CVDownloadButton cvPath={meta.cvPdfPath} />
        <a class="button button-secondary" href="#contact">
          <Icon name="mail" size={18} />
          <span>Me contacter</span>
        </a>
      </div>
    </div>

    <div class="hero-panel surface-card reveal" aria-label="Résumé du profil">
      <div class="profile-photo" aria-hidden={profile.photo ? "false" : "true"}>
        {profile.photo ? (
          <img src={profile.photo.src} alt={profile.photo.alt} width="320" height="320" fetchpriority="high" />
        ) : (
          <span>{initials}</span>
        )}
      </div>
      <dl>
        <div>
          <dt>Localisation</dt>
          <dd><Icon name="map-pin" size={18} /> {profile.location}</dd>
        </div>
        <div>
          <dt>Positionnement</dt>
          <dd>Support IT, coordination et IA appliquée</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4rem, 10vw, 8rem) clamp(3rem, 7vw, 6rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.22fr) minmax(280px, 0.78fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }

  .availability {
    margin: 0 0 1rem;
    color: var(--color-accent);
    font-weight: 800;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 7vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero-title {
    max-width: 760px;
    margin: 1.4rem 0 0;
    color: var(--color-text);
    font-size: clamp(1.15rem, 2.4vw, 1.6rem);
    font-weight: 750;
    line-height: 1.35;
  }

  .hero-tagline {
    max-width: 640px;
    margin: 1rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .hero-panel {
    padding: clamp(1rem, 2.5vw, 1.5rem);
  }

  .profile-photo {
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: linear-gradient(145deg, var(--color-accent-soft), #ffffff);
    color: var(--color-accent);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 850;
  }

  .profile-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 1.2rem 0 0;
  }

  dt {
    color: var(--color-subtle);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  dd {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.25rem 0 0;
    color: var(--color-text);
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 100%;
    }

    .hero-panel {
      max-width: 420px;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: clamp(2.25rem, 14vw, 3.2rem);
      line-height: 1.02;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions :global(.button) {
      width: 100%;
    }
  }
</style>
